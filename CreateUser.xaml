<Page x:Class="Курсовая_3_курс.CreateUser"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Курсовая_3_курс"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="550"
      Title="CreateUser"
      Background="White">

    <Grid>
        <Border BorderBrush="#2C3E50" 
                BorderThickness="1" 
                Background="White" 
                Padding="25"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                CornerRadius="10"
                Width="450">
            <StackPanel>
                <Button Content="← Назад" 
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#2C3E50"
                        Cursor="Hand"
                        FontSize="14"
                        Margin="0 0 0 15"
                        Name="return_login"
                        Click="return_login_Click"/>
                <StackPanel>
                    <TextBlock Text="Создание аккаунта" 
                       HorizontalAlignment="Center" 
                       Margin="0 0 0 20"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#2C3E50"/>

                    <Button Name="helpBtn"
                        Content="?"
                        Width="30"
                        Height="30"
                        Background="#2C3E50"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        Cursor="Hand"
                        HorizontalAlignment="Right"
                        Margin="0,-50,0,0"
                        Click="helpBtn_Click"/>
                </StackPanel>

                <TextBlock Text="Логин" Margin="0 0 0 5" FontSize="14" FontWeight="SemiBold"/>
                <Border BorderBrush="Black" 
                        BorderThickness="1" 
                        Background="White" 
                        Padding="2"
                        CornerRadius="5"
                        Margin="0 0 0 15">
                    <TextBox Padding="8" 
                             BorderThickness="0"
                             Name="login"
                             FontSize="14"
                             Height="35"/>
                </Border>

                <TextBlock Text="ФИО" Margin="0 0 0 5" FontSize="14" FontWeight="SemiBold"/>
                <Border BorderBrush="Black" 
                        BorderThickness="1" 
                        Background="White" 
                        Padding="2"
                        CornerRadius="5"
                        Margin="0 0 0 15">
                    <TextBox Padding="8" 
                             BorderThickness="0"
                             Name="fullName"
                             FontSize="14"
                             Height="35"/>
                </Border>

                <StackPanel>
                    <TextBlock Text="Группа" Margin="0 0 0 5" FontSize="14" FontWeight="SemiBold"/>
                    <Border BorderBrush="Black" 
                        BorderThickness="1" 
                        Background="White" 
                        Padding="2"
                        CornerRadius="5"
                        Margin="0 0 0 15"
                    >
                        <ComboBox x:Name="GroupsComboBox"
                           BorderThickness="0"
                           Height="35"
                           FontSize="14"/>
                    </Border>
                </StackPanel>

                <TextBlock Text="Пароль" Margin="0 0 0 5" FontSize="14" FontWeight="SemiBold"/>
                <Border BorderBrush="Black" 
                        BorderThickness="1" 
                        Background="White" 
                        Padding="2"
                        CornerRadius="5"
                        Margin="0 0 0 15">
                    <PasswordBox Padding="8" 
                             BorderThickness="0"
                             Name="password"
                             FontSize="14"
                             Height="35"/>
                </Border>

                <TextBlock Text="Повторите пароль" Margin="0 0 0 5" FontSize="14" FontWeight="SemiBold"/>
                <Border BorderBrush="Black" 
                        BorderThickness="1" 
                        Background="White" 
                        Padding="2"
                        CornerRadius="5"
                        Margin="0 0 0 20">
                    <PasswordBox Padding="8" 
                             BorderThickness="0"
                             Name="repeat_password"
                             FontSize="14"
                             Height="35"/>
                </Border>

                <Button Content="Создать аккаунт" 
                        Width="180"
                        Height="40"
                        Name="Create_user_button"
                        Background="#2C3E50"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        Cursor="Hand"
                        Click="Create_user_button_Click"
                        HorizontalAlignment="Center">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>