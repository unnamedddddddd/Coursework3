<Page x:Class="Курсовая_3_курс.CreateUser"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Курсовая_3_курс"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CreateUser"
      Background="White">

    <Grid>
        <Border BorderBrush="Black" 
             BorderThickness="1" 
             Background="White" 
             Padding="20"
             HorizontalAlignment="Center" 
             VerticalAlignment="Center"
             CornerRadius="5"
             Width="350"
        >
            <StackPanel>
                <Button Content="← Назад" 
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#0078D4"
                    Cursor="Hand"
                    FontSize="14"
                    Margin="0 0 0 10"
                    Name="return_login"
                    Click="return_login_Click"
                />
                <TextBlock Text="Создать аккаунт" 
                    HorizontalAlignment="Center" 
                    Margin="0 0 0 10"
                    FontSize="18"
                    FontWeight="Bold"/>

                <StackPanel Margin="0 0 0 10">
                    <TextBlock Text="Логин" Margin="0 0 0 3"/>
                    <Border  
                 BorderBrush="Black" 
                 BorderThickness="1" 
                 Background="White" 
                 Padding="1"
                 CornerRadius="5"
             >
                        <TextBox 
                            Padding="3" 
                            BorderThickness="0"
                            Name="login"
                        />
                    </Border>
                </StackPanel>
                
                <StackPanel Margin="0 0 0 15">
                    <TextBlock Text="ФИО" Margin="0 0 0 3"/>
                    <Border  
                        BorderBrush="Black" 
                        BorderThickness="1" 
                        Background="White" 
                        Padding="1"
                        CornerRadius="5"
                    >
                        <TextBox
                            Padding="3" 
                            BorderThickness="0"
                            Name="fullName"
                        />
                    </Border>
                </StackPanel>
                <StackPanel Margin="0 0 0 15">
                    <TextBlock Text="Пароль" Margin="0 0 0 3"/>
                    <Border  
                        BorderBrush="Black" 
                        BorderThickness="1" 
                        Background="White" 
                        Padding="1"
                        CornerRadius="5"
                    >
                    <TextBox
                       Padding="3" 
                       BorderThickness="0"
                       Name="password"
                    />   
                    </Border>
                </StackPanel>
                <StackPanel Margin="0 0 0 15">
                    <TextBlock Text="Повторитe пароль" Margin="0 0 0 3"/>
                    <Border  
                        BorderBrush="Black" 
                        BorderThickness="1" 
                        Background="White" 
                        Padding="1"
                        CornerRadius="5"
                    >
                        <TextBox 
                            Padding="3" 
                            BorderThickness="0"
                            Name="repeat_password"
                        />
                    </Border>
                </StackPanel>
                <Border 
                     BorderBrush="#0078D4" 
                     BorderThickness="1" 
                     CornerRadius="5"
                     HorizontalAlignment="Center"
                >
                    <Button Content="Создать аккаунт" 
                         Width="100"
                         Name="Create_user_button"
                         BorderThickness="0"
                         Background="#0078D4"
                         Foreground="White"
                         FontWeight="Bold"
                         Cursor="Hand"
                         Click="Create_user_button_Click"
                    />
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Page>
