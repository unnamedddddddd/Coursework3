<UserControl x:Class="Курсовая_3_курс.ShowUsers"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Курсовая_3_курс"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="White" 
                BorderBrush="#2C3E50" 
                BorderThickness="0,0,0,1"
                Padding="15"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="📋 Просмотр пользователей" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Фильтр по роли" 
                                   Margin="0,0,0,5" 
                                   FontSize="12" 
                                   FontWeight="SemiBold"/>
                        <Border BorderBrush="Black" 
                                BorderThickness="1" 
                                CornerRadius="5" 
                                Padding="2" 
                                Width="150">
                            <ComboBox x:Name="RolesComboBox" 
                                      BorderThickness="0"
                                      FontSize="13"
                                      Height="32" 
                                      SelectionChanged="RolesComboBox_SelectionChanged" />
                        </Border>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,0" Name="GroupsStackPanel" Visibility="Collapsed">
                        <TextBlock Text="Фильтр по группе" 
                                   Margin="0,0,0,5" 
                                   FontSize="12" 
                                   FontWeight="SemiBold"/>
                        <Border BorderBrush="Black" 
                                BorderThickness="1" 
                                CornerRadius="5" 
                                Padding="2" 
                                Width="150">
                            <ComboBox x:Name="GroupsComboBox" 
                                      BorderThickness="0"
                                      DisplayMemberPath="group_name"
                                      SelectedValuePath="group_id"
                                      FontSize="13"
                                      Height="32" 
                                      SelectionChanged="GroupsComboBox_SelectionChanged"/>
                        </Border>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Bottom">
                        <Button Content="Сбросить" 
                                Width="100"
                                Height="32"
                                Name="ResetBtn"
                                Background="#2C3E50"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="12"
                                Cursor="Hand"
                                Click="ResetBtn_Click"
                                Margin="10,0,0,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid x:Name="UsersTable" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  ColumnWidth="*"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5"
                  RowHeight="35"
                  FontSize="13"
                  Margin="15,0,15,15"
                  BorderBrush="#2C3E50"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding user_id}" Width="50"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding user_login}" MinWidth="120"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding full_name}" MinWidth="180"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding role_name}" MinWidth="120"/>
                <DataGridTextColumn Header="Группа" Binding="{Binding group_name}" MinWidth="100"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding phone_number}" MinWidth="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>