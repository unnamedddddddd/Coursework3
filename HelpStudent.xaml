<Window x:Class="Курсовая_3_курс.HelpStudent"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Курсовая_3_курс"
        mc:Ignorable="d"
        Title="Помощь - Панель студента" 
        Height="700" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="ИНСТРУКЦИЯ ПО РАБОТЕ С ПАНЕЛЬЮ СТУДЕНТА" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"
                       Foreground="#2C3E50"/>

            <Border Background="#E8F4FD" CornerRadius="5" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="ПРОСМОТР ЗАПИСЕЙ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="1. Нажмите кнопку Просмотр записей" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="2. Откроется таблица с вашими записями посещаемости" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="3. Вы можете фильтровать записи по предмету, статусу и преподавателю" FontSize="13" Margin="0,3"/>
                </StackPanel>
            </Border>

            <Border Background="#FFF8E1" CornerRadius="5" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="ФИЛЬТРАЦИЯ ЗАПИСЕЙ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="1. Выберите значение в любом фильтре" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="2. Таблица автоматически обновится" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="3. Несколько фильтров работают одновременно" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="4. Нажмите кнопку Сбросить для очистки всех фильтров" FontSize="13" Margin="0,3"/>
                </StackPanel>
            </Border>

            <Border Background="#E8F5E9" CornerRadius="5" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="ДОСТУПНЫЕ ФИЛЬТРЫ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="• Предмет - выбор учебного предмета" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="• Статус - присутствовал, отсутствовал, опоздал, уважительная причина" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="• Преподаватель - выбор преподавателя" FontSize="13" Margin="0,3"/>
                </StackPanel>
            </Border>

            <Border Background="#FFEBEE" CornerRadius="5" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="ВЫХОД ИЗ СИСТЕМЫ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="1. Нажмите кнопку Выход" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="2. Подтвердите действие в диалоговом окне" FontSize="13" Margin="0,3"/>
                </StackPanel>
            </Border>

            <Button Content="Закрыть" 
                    Width="120"
                    Height="35"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Click="Button_Click"
                    Background="#2C3E50"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="14"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>