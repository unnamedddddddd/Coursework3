<Window x:Class="Курсовая_3_курс.HelpAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Курсовая_3_курс"
        mc:Ignorable="d"
        Title="Помощь - Панель администратора" 
        Height="850" 
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="ИНСТРУКЦИЯ ПО РАБОТЕ С ПАНЕЛЬЮ АДМИНИСТРАТОРА" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"
                       Foreground="#2C3E50"/>

            <Border Background="#E8F4FD" CornerRadius="5" Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="ПРОСМОТР ПОЛЬЗОВАТЕЛЕЙ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="1. Нажмите кнопку Пользователи" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="2. Откроется таблица со всеми пользователями системы" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="3. Можно фильтровать по роли и группе" FontSize="13" Margin="0,3"/>
                </StackPanel>
            </Border>

            <Border Background="#FFF8E1" CornerRadius="5" Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="СОЗДАНИЕ ПОЛЬЗОВАТЕЛЯ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="1. Нажмите кнопку Создать пользователя" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="2. Заполните все поля (логин, ФИО, роль, пароль)" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="3. Для студента выберите группу" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="4. Нажмите кнопку Создать аккаунт" FontSize="13" Margin="0,3"/>
                </StackPanel>
            </Border>

            <Border Background="#E8F5E9" CornerRadius="5" Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="ИЗМЕНЕНИЕ РОЛИ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="1. Нажмите кнопку Изменить роль" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="2. Выберите пользователя из списка" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="3. Выберите новую роль" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="4. Нажмите Обновить роль и подтвердите действие" FontSize="13" Margin="0,3"/>
                </StackPanel>
            </Border>

            <Border Background="#F3E5F5" CornerRadius="5" Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="ПРОСМОТР ЗАПИСЕЙ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="1. Нажмите кнопку Записи" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="2. Откроется таблица со всеми записями посещаемости" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="3. Можно фильтровать по студенту, предмету, статусу, преподавателю" FontSize="13" Margin="0,3"/>
                </StackPanel>
            </Border>

            <Border Background="#FFEBEE" CornerRadius="5" Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="ВЫХОД ИЗ СИСТЕМЫ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="1. Нажмите кнопку Выход" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="2. Подтвердите действие в диалоговом окне" FontSize="13" Margin="0,3"/>
                </StackPanel>
            </Border>

            <Button Content="Закрыть" 
                    Width="120"
                    Height="35"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Click="CloseBtn_Click"
                    Background="#2C3E50"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="14"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>