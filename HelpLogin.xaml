<Window x:Class="Курсовая_3_курс.HelpLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Курсовая_3_курс"
        mc:Ignorable="d"
        Title="Помощь - Авторизация" 
        Height="600" 
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="ИНСТРУКЦИЯ ПО ВХОДУ" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"
                       Foreground="#2C3E50"/>

            <Border Background="#E8F4FD" CornerRadius="5" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="КАК ВОЙТИ В СИСТЕМУ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="1️ - Введите логин в поле «Логин»" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="2️ - Введите пароль в поле «Пароль»" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="3️ - Нажмите кнопку «Войти»" FontSize="13" Margin="0,3"/>
                </StackPanel>
            </Border>

            <Border Background="#FFF8E1" CornerRadius="5" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="НЕТ АККАУНТА?" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="• Нажмите кнопку «Создать аккаунт» под кнопкой входа" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="• Заполните все поля и зарегистрируйтесь" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="• После регистрации вы сможете войти в систему" FontSize="13" Margin="0,3"/>
                </StackPanel>
            </Border>

            <Border Background="#E8F5E9" CornerRadius="5" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="ТЕСТОВЫЕ АККАУНТЫ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,8"
                               Foreground="#2E7D32"/>
                    <Border Background="White" CornerRadius="3" Padding="8" Margin="0,5,0,0" Height="96">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Роль" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Логин" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Пароль" FontWeight="Bold" FontSize="12"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Студент" FontSize="12" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="denis" FontSize="12" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="123" FontSize="12" Margin="0,3"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Преподаватель" FontSize="12" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="ivan" FontSize="12" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="123" FontSize="12" Margin="0,3"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Администратор" FontSize="12" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="admin" FontSize="12" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="123456" FontSize="12" Margin="0,3"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Button Content="Закрыть" 
                    Width="120"
                    Height="35"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Click="Button_Click"
                    Background="#2C3E50"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="14"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>