<Page x:Class="Курсовая_3_курс.Home"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Курсовая_3_курс"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Home"
      Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition Height="0.30*"/>
            <RowDefinition Height="0.70*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0078D4">
            <Viewbox Stretch="None" HorizontalAlignment="Right" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Margin="0 0 5 5">
                    <TextBlock Text="Пользователь: " FontWeight="Bold" Foreground="White" FontSize="20"/>
                    <TextBlock FontWeight="Bold" Foreground="White" Name="userFullName" FontSize="20"/>
                </StackPanel>
            </Viewbox>
        </Border>
        
        
        
        <DataGrid Grid.Row="3"/>
    </Grid>
</Page>