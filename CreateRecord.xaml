<UserControl x:Class="Курсовая_3_курс.CreateRecord"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="550">
    <Grid>
        <Border BorderBrush="#2C3E50" 
                BorderThickness="1" 
                Background="White" 
                Padding="25"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                CornerRadius="10"
                Width="480">

            <StackPanel>
                <TextBlock Text="Создание записи" 
                           HorizontalAlignment="Center" 
                           Margin="0 0 0 25"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#2C3E50"/>

                <TextBlock Text="Студент" Margin="0 0 0 5" FontSize="13" FontWeight="SemiBold"/>
                <Border BorderBrush="Black" BorderThickness="1" CornerRadius="5" Padding="2" Margin="0 0 0 15">
                    <ComboBox x:Name="StudentComboBox" 
                              BorderThickness="0"
                              DisplayMemberPath="full_name"
                              SelectedValuePath="user_id"
                              FontSize="16"
                              Height="35"/>
                </Border>

                <TextBlock Text="Предмет" Margin="0 0 0 5" FontSize="13" FontWeight="SemiBold"/>
                <Border BorderBrush="Black" BorderThickness="1" CornerRadius="5" Padding="2" Margin="0 0 0 15">
                    <ComboBox x:Name="SubjectComboBox" 
                              BorderThickness="0"
                              DisplayMemberPath="subject_name"
                              SelectedValuePath="assignment_id"
                              FontSize="16"
                              Height="35"/>
                </Border>

                <TextBlock Text="Статус" Margin="0 0 0 5" FontSize="13" FontWeight="SemiBold"/>
                <Border BorderBrush="Black" BorderThickness="1" CornerRadius="5" Padding="2" Margin="0 0 0 15">
                    <ComboBox x:Name="StatusComboBox" 
                              BorderThickness="0" 
                              SelectedIndex="0"
                              FontSize="16"
                              Height="35">
                        <ComboBoxItem Content="Присутствовал" Tag="Присутствовал"/>
                        <ComboBoxItem Content="Отсутствовал" Tag="Отсутствовал"/>
                        <ComboBoxItem Content="Опоздал" Tag="Опоздал"/>
                        <ComboBoxItem Content="Уважительная причина" Tag="Уважительная причина"/>
                    </ComboBox>
                </Border>

                <TextBlock Text="Дата и время" Margin="0 0 0 5" FontSize="13" FontWeight="SemiBold"/>
                <Border BorderBrush="Black" BorderThickness="1" Background="White" Padding="2" CornerRadius="5" Margin="0 0 0 20">
                    <xctk:DateTimePicker x:Name="DateTimePicker" 
                                         BorderThickness="0"
                                         Height="35"
                                         Value="{Binding CurrentDateTime}"/>
                </Border>

                <Button Content="Сохранить" 
                        Width="130"
                        Height="38"
                        Name="SaveButton"
                        Background="#2C3E50"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        Cursor="Hand"
                        Click="SaveButton_Click"
                        HorizontalAlignment="Center">
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>