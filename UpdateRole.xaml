<UserControl x:Class="Курсовая_3_курс.UpdateRole"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Курсовая_3_курс"
             mc:Ignorable="d" 
             d:DesignHeight="480" d:DesignWidth="800">
    <Grid>
        <Border 
             BorderThickness="1" 
             Background="White" 
             Padding="40"
             BorderBrush="#2C3E50"
             HorizontalAlignment="Center" 
             VerticalAlignment="Center"
             CornerRadius="10"
             Width="650"
             Height="550"
        >
            <StackPanel>
                <TextBlock Text="Изменение роли пользователя" 
                    HorizontalAlignment="Center" 
                    Margin="0 0 0 30"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="#2C3E50"
                />

                <StackPanel Margin="0 0 0 25">
                    <TextBlock Text="Выберите пользователя" 
                               Margin="0 0 0 8" 
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <Border
                        BorderBrush="#2C3E50"
                        BorderThickness="2"
                        CornerRadius="8"
                        Padding="1"
                        Background="White"
                    >
                        <ComboBox 
                            BorderThickness="0"
                            Name="UsersComboBox"
                            SelectedIndex="0"
                            SelectedValuePath="user_id"
                            DisplayMemberPath="user_login"
                            Height="45"
                            FontSize="16" SelectionChanged="UsersComboBox_SelectionChanged"
                        />
                    </Border>
                </StackPanel>

                <StackPanel>
                    <Border Background="#E8F4FD" 
                        CornerRadius="8" 
                        Padding="15" 
                        Margin="0 0 0 15">
                        <StackPanel>
                            <TextBlock Text="Текущая роль" 
                                   FontWeight="Bold" 
                                   Margin="0 0 0 8"
                                   FontSize="14"/>
                            <TextBlock x:Name="CurrentRoleText" 
                                   Text="-" 
                                   FontSize="16"
                                   Foreground="#2C3E50"
                                   FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <StackPanel Margin="0 0 0 35">
                    <TextBlock Text="Новая роль" 
                               Margin="0 0 0 8" 
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <Border
                        BorderBrush="#2C3E50"
                        BorderThickness="2"
                        CornerRadius="8"
                        Padding="1"
                        Background="White"
                    >
                        <ComboBox 
                            BorderThickness="0"
                            Name="RolesComboBox"
                            SelectedValuePath="role_id"
                            DisplayMemberPath="role_name"
                            SelectedIndex="0"
                            Height="45"
                            FontSize="16"
                        />
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <Border BorderBrush="Black" BorderThickness="1" CornerRadius="5" Margin="0,0,15,0">
                        <Button Content="Обновить роль" 
                            Width="140"
                            Height="45"
                            Name="UpdateBtn"
                            BorderThickness="0"
                            Background="#2C3E50"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="16"
                            Cursor="Hand"
                            Click="UpdateBtn_Click"/>
                    </Border>

                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>