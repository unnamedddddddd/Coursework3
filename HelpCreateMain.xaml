<Window x:Class="Курсовая_3_курс.HelpCreateMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Курсовая_3_курс"
        mc:Ignorable="d"
        Title="Помощь - Создание аккаунта" 
        Height="650" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="ИНСТРУКЦИЯ ПО РЕГИСТРАЦИИ" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"
                       Foreground="#2C3E50"/>

            <Border Background="#E8F4FD" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="1️ - Заполните все поля" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="• Логин (придумайте уникальный)" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• ФИО (ваше полное имя)" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Пароль" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Повторите пароль" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Группа (выберите из списка)" FontSize="13" Margin="0,2"/>
                </StackPanel>
            </Border>

            <Border Background="#FFF8E1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="2️ - Нажмите кнопку «Создать аккаунт»" 
                               FontWeight="Bold" 
                               FontSize="14"/>
                    <TextBlock Text="После заполнения всех полей нажмите кнопку для создания аккаунта" 
                               FontSize="13" 
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#FFEBEE" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="ВАЖНО" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Foreground="#C62828"/>
                    <TextBlock Text="• Пароль и повтор должны совпадать" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• При регистрации автоматически присваивается роль «Студент»" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Логин должен быть уникальным" FontSize="13" Margin="0,2"/>
                </StackPanel>
            </Border>

            <Border Background="#E8F5E9" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="ПРИМЕР ДАННЫХ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Foreground="#2E7D32"/>
                    <TextBlock Text="Логин: student2024" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="ФИО: Иванов Иван Иванович" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="Пароль: 123456" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="Группа: ИТ-21" FontSize="13" Margin="0,2"/>
                </StackPanel>
            </Border>

            <Button Content="Закрыть" 
                    Width="120"
                    Height="35"
                    HorizontalAlignment="Center"
                    Click="Button_Click"
                    Background="#2C3E50"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="14"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>