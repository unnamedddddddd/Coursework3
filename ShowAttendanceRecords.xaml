<UserControl x:Class="Курсовая_3_курс.ShowAttendanceRecords"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Курсовая_3_курс"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="White" 
                BorderBrush="#2C3E50" 
                BorderThickness="0,0,0,1"
                Padding="15"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Просмотр посещений" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <StackPanel Margin="0,0,15,0" Visibility="Collapsed" Name="StackPanelStudentComboBox">
                        <TextBlock Text="Фильтр по студенту" 
                            Margin="0,0,0,5" 
                            FontSize="12" 
                            FontWeight="SemiBold"/>
                        <Border BorderBrush="Black" 
                            BorderThickness="1" 
                            CornerRadius="5" 
                            Padding="2" 
                            Width="180">
                            <ComboBox x:Name="StudentComboBox" 
                                  DisplayMemberPath="full_name" 
                                  SelectedValuePath="user_id"
                                  SelectionChanged="StudentComboBox_SelectionChanged"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Фильтр по предмету" 
                                   Margin="0,0,0,5" 
                                   FontSize="12" 
                                   FontWeight="SemiBold"/>
                        <Border BorderBrush="Black" 
                                BorderThickness="1" 
                                CornerRadius="5" 
                                Padding="2" 
                                Width="180">
                            <ComboBox x:Name="SubjectComboBox" 
                              DisplayMemberPath="subject_name"
                              SelectedValuePath="assignment_id"
                              FontSize="13"
                              Height="32" 
                              SelectionChanged="SubjectComboBox_SelectionChanged"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Фильтр по статусу" 
                                   Margin="0,0,0,5" 
                                   FontSize="12" 
                                   FontWeight="SemiBold"/>
                        <Border BorderBrush="Black" 
                                BorderThickness="1" 
                                CornerRadius="5" 
                                Padding="2" 
                                Width="150">
                            <ComboBox x:Name="StatusFilterComboBox" 
                                      BorderThickness="0"
                                      FontSize="13"
                                      Height="32" SelectionChanged="StatusFilterComboBox_SelectionChanged"
                            >
                                <ComboBoxItem Content="Все" IsSelected="True"/>
                                <ComboBoxItem Content="Присутствовал"/>
                                <ComboBoxItem Content="Отсутствовал"/>
                                <ComboBoxItem Content="Опоздал"/>
                                <ComboBoxItem Content="Уважительная причина"/>
                            </ComboBox>
                        </Border>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Фильтр по преподавателю" 
                            Margin="0,0,0,5" 
                            FontSize="12" 
                            FontWeight="SemiBold"/>
                        <Border BorderBrush="Black" 
                            BorderThickness="1" 
                            CornerRadius="5" 
                            Padding="2" 
                            Width="180">
                            <ComboBox x:Name="TeacherComboBox" 
                                    DisplayMemberPath="full_name" 
                                    SelectedValuePath="user_id" 
                                    SelectionChanged="TeacherComboBox_SelectionChanged"/>
                        </Border>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Bottom">
                        <Button Content="Сбросить" 
                                Width="100"
                                Height="32"
                                Name="ResetBtn"
                                Background="#2C3E50"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="12"
                                Cursor="Hand"
                                Click="ResetBtn_Click"
                                Margin="10,0,0,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid x:Name="RecordsTable" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  ColumnWidth="*"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5"
                  RowHeight="35"
                  FontSize="13" 
                  SelectionChanged="RecordsTable_SelectionChanged"
                  Margin="15,0,15,15"
                  BorderBrush="#2C3E50"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding record_id}" Width="50"/>
                <DataGridTextColumn Header="Студент" Binding="{Binding student_name}" Width="*"/>
                <DataGridTextColumn Header="Предмет" Binding="{Binding subject_name}" Width="*"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding status}" Width="100"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding created_at, StringFormat='dd.MM.yyyy HH:mm:ss'}" Width="150"/>
                <DataGridTextColumn Header="Дата обновления" Binding="{Binding updated_at, StringFormat='dd.MM.yyyy HH:mm:ss'}" Width="150"/>
                <DataGridTextColumn Header="Преподаватель" Binding="{Binding teacher_name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>