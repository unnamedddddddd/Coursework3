<UserControl x:Class="Курсовая_3_курс.UpdateRecord"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" 
                BorderBrush="#2C3E50" 
                BorderThickness="1" 
                Background="White" 
                Padding="15"
                CornerRadius="10"
                Margin="10">
            <StackPanel>
                <TextBlock Text="Выберите запись" 
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0 0 0 15"
                           HorizontalAlignment="Center"/>

                <DataGrid x:Name="RecordsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          SelectionChanged="RecordsGrid_SelectionChanged"
                          Height="400"
                          Margin="0 0 0 10"
                >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="student_id" Binding="{Binding student_id}" Width="0" Visibility="Hidden"/>
                        <DataGridTextColumn Header="assignment_id" Binding="{Binding assignment_id}" Width="0" Visibility="Hidden"/>
                        
                        <DataGridTextColumn Header="ID" Binding="{Binding record_id}" Width="50"/>
                        <DataGridTextColumn Header="Студент" Binding="{Binding student_name}" Width="*"/>
                        <DataGridTextColumn Header="Предмет" Binding="{Binding subject_name}" Width="*"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding status}" Width="*"/>
                        <DataGridTextColumn Header="Дата создания" Binding="{Binding updated_at, StringFormat='dd.MM.yyyy HH:mm:ss'}"  Width="*"/>
                        <DataGridTextColumn Header="Дата обновления"  Binding="{Binding updated_at, StringFormat='dd.MM.yyyy HH:mm:ss'}"  Width="*"/>
                        <DataGridTextColumn Header="Преподаватель" Binding="{Binding teacher_name}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" 
                BorderBrush="#2C3E50" 
                BorderThickness="1" 
                Background="White" 
                Padding="20"
                CornerRadius="10"
                Margin="10">
            <StackPanel>
                <TextBlock Text="Редактирование записи" 
                           HorizontalAlignment="Center" 
                           Margin="0 0 0 20"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#2C3E50"/>

                <TextBlock Text="ID записи" Margin="0 0 0 5" FontSize="13" FontWeight="SemiBold"/>
                <Border BorderBrush="Black" BorderThickness="1" CornerRadius="5" Padding="2" Margin="0 0 0 15">
                    <TextBlock x:Name="RecordIdText" Height="35" Padding="5" Background="#F0F0F0"/>
                </Border>

                <Border Background="#E8F4FD" CornerRadius="8" Padding="12" Margin="0 0 0 15">
                    <StackPanel>
                        <TextBlock Text="Текущий студент" FontWeight="Bold" Margin="0 0 0 8" FontSize="13"/>
                        <TextBlock x:Name="CurrentStudentText" Text="-" FontSize="14" Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Новый студент" Margin="0 0 0 5" FontSize="13" FontWeight="SemiBold"/>
                <Border BorderBrush="Black" BorderThickness="1" CornerRadius="5" Padding="2" Margin="0 0 0 15">
                    <ComboBox Name="StudentComboBox"
                              SelectedIndex="0"
                              DisplayMemberPath="full_name"
                              SelectedValuePath="user_id"
                              BorderThickness="0" 
                              Height="35"/>
                </Border>

                <Border Background="#E8F4FD" CornerRadius="8" Padding="12" Margin="0 0 0 15">
                    <StackPanel>
                        <TextBlock Text="Текущий предмет" FontWeight="Bold" Margin="0 0 0 8" FontSize="13"/>
                        <TextBlock x:Name="CurrentSubjectText" Text="-" FontSize="14" Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Новый предмет" Margin="0 0 0 5" FontSize="13" FontWeight="SemiBold"/>
                <Border BorderBrush="Black" BorderThickness="1" CornerRadius="5" Padding="2" Margin="0 0 0 15">
                    <ComboBox Name="SubjectComboBox"
                              SelectedIndex="0"
                              DisplayMemberPath="subject_name"
                              SelectedValuePath="assignment_id"
                              BorderThickness="0"
                              Height="35"/>
                </Border>

                <Border Background="#E8F4FD" CornerRadius="8" Padding="12" Margin="0 0 0 15">
                    <StackPanel>
                        <TextBlock Text="Текущий статус" FontWeight="Bold" Margin="0 0 0 8" FontSize="13"/>
                        <TextBlock x:Name="CurrentStatusText" Text="-" FontSize="14" Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Новый статус" Margin="0 0 0 5" FontSize="13" FontWeight="SemiBold"/>
                <Border BorderBrush="Black" BorderThickness="1" CornerRadius="5" Padding="2" Margin="0 0 0 15">
                    <ComboBox x:Name="StatusComboBox" BorderThickness="0" SelectedIndex="0" Height="35">
                        <ComboBoxItem Content="Присутствовал" Tag="Присутствовал"/>
                        <ComboBoxItem Content="Отсутствовал" Tag="Отсутствовал"/>
                        <ComboBoxItem Content="Опоздал" Tag="Опоздал"/>
                        <ComboBoxItem Content="Уважительная причина" Tag="Уважительная причина"/>
                    </ComboBox>
                </Border>

                <Border Background="#E8F4FD" CornerRadius="8" Padding="12" Margin="0 0 0 15">
                    <StackPanel>
                        <TextBlock Text="Текущее время создания" FontWeight="Bold" Margin="0 0 0 8" FontSize="13"/>
                        <TextBlock x:Name="CurrentDateTime" Text="-" FontSize="14" Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Новая дата и время" Margin="0 0 0 5" FontSize="13" FontWeight="SemiBold"/>
                <Border BorderBrush="Black" BorderThickness="1" Background="White" Padding="2" CornerRadius="5" Margin="0 0 0 20">
                    <xctk:DateTimePicker x:Name="DateTimePicker" 
                                         BorderThickness="0"
                                         Height="35"
                                        />
                </Border>

                <Button Content="Обновить" 
                        Width="130"
                        Height="38"
                        Name="UpdateButton"
                        Background="#2C3E50"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        Cursor="Hand"
                        Click="UpdateButton_Click"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>