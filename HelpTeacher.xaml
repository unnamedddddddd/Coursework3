<Window x:Class="Курсовая_3_курс.HelpTeacher"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Курсовая_3_курс"
        mc:Ignorable="d"
        Title="Помощь - Панель преподавателя" 
        Height="700" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="ПОМОЩЬ: ПАНЕЛЬ ПРЕПОДАВАТЕЛЯ" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"
                       Foreground="#2C3E50"/>

            <Border Background="#E8F4FD" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="ПРОСМОТР ЗАПИСЕЙ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="• Нажмите кнопку «Просмотр записей»" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Откроется таблица со всеми записями посещаемости" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Можно фильтровать по студенту, предмету, статусу и преподавателю" FontSize="13" Margin="0,2"/>
                </StackPanel>
            </Border>

            <Border Background="#FFF8E1" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="СОЗДАНИЕ ЗАПИСИ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="• Нажмите кнопку «Создать запись»" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Выберите студента, предмет, статус и дату" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Нажмите «Сохранить» — запись добавится в базу" FontSize="13" Margin="0,2"/>
                </StackPanel>
            </Border>

            <Border Background="#E8F5E9" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="РЕДАКТИРОВАНИЕ ЗАПИСИ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="• Нажмите кнопку «Редактировать запись»" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Выберите запись в таблице (кликните на строку)" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Данные подгрузятся в форму" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Измените нужные поля и нажмите «Обновить»" FontSize="13" Margin="0,2"/>
                </StackPanel>
            </Border>

            <Border Background="#F3E5F5" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="ФИЛЬТРАЦИЯ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="• Выберите значение в любом фильтре" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Таблица автоматически обновится" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Несколько фильтров работают одновременно" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Нажмите «Сбросить» для очистки всех фильтров" FontSize="13" Margin="0,2"/>
                </StackPanel>
            </Border>

            <Button Content="Закрыть" 
                    Width="120"
                    Height="35"
                    HorizontalAlignment="Center"
                    Margin="0,15,0,0"
                    Click="Button_Click"
                    Background="#2C3E50"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="14"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>