<Page x:Class="Курсовая_3_курс.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="LoginPage"
      Background="White">
    <Grid>
        <Viewbox Stretch="Uniform" MaxWidth="400" MaxHeight="500">
            <Border 
                BorderBrush="Black" 
                BorderThickness="1" 
                Background="White" 
                Padding="30"
                CornerRadius="5"
                Width="350">
                <StackPanel>
                    <TextBlock 
                        Text="Вход" 
                        HorizontalAlignment="Center" 
                        Margin="0 0 0 15"
                        FontSize="22"
                        FontWeight="Bold"/>

                    <StackPanel Margin="0 0 0 12">
                        <TextBlock Text="Логин" Margin="0 0 0 5" FontSize="14"/>
                        <Border 
                            BorderBrush="Black" 
                            BorderThickness="1" 
                            CornerRadius="5"
                            Padding="1">
                            <TextBox 
                                Padding="8" 
                                BorderThickness="0" 
                                FontSize="14"
                                Height="35"
                                Name="login_textBox"
                                />
                        </Border>
                    </StackPanel>

                    <StackPanel Margin="0 0 0 20">
                        <TextBlock Text="Пароль" Margin="0 0 0 5" FontSize="14"/>
                        <Border 
                            BorderBrush="Black" 
                            BorderThickness="1" 
                            CornerRadius="5"
                            Padding="1">
                            <TextBox 
                                Padding="8" 
                                BorderThickness="0" 
                                FontSize="14"
                                Height="35"
                                Name="password_textBox"
                                />
                        </Border>
                    </StackPanel>

                    <Button Content="Войти" 
                            Name="Check_Auth"
                            Background="#2C3E50"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="15"
                            BorderThickness="0"
                            Height="40"
                            Cursor="Hand"
                            Click="Check_Auth_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBlock HorizontalAlignment="Center" Margin="0 15 0 0">
                        <Hyperlink TextDecorations="None" 
                                   Foreground="#2C3E50"
                                   Click="CreateAccount_Click">
                            Нет аккаунта? Создайте
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Viewbox>
    </Grid>
</Page>